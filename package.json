{
  "name": "innospace-bookings",
  "version": "1.0.0",
  "private": true,
  "description": "Booking microservice for Innospace Tirana: receives booking submissions, stores them in SQLite, emails a notification, and shows a dashboard.",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "next": "^15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "4.1.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.3",
    "typescript": "5.7.3",
    "vitest": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10"
  }
}
