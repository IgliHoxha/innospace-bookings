# Every var below marked "required" has NO code default: the app throws on first
# use if it is unset or blank, so a misconfigured deploy fails loudly instead of
# quietly running on a fallback. Optional vars are feature flags or detail lines.

# ---- Email (Resend): confirm/cancel emails to customers ----
# Optional. Get a key at https://resend.com/api-keys. If empty, emails are skipped.
RESEND_API_KEY=
# Required (when sending). Verified Resend sender, or onboarding@resend.dev until
# your domain is verified.
EMAIL_FROM=onboarding@resend.dev
# Optional. Base URL this app is served from, used for the logo in emails.
# Defaults to https://booking.innospacetirana.com
APP_BASE_URL=

# ---- Dashboard login ----
# Required. No admin/change-me fallback: login throws until both are set.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
# Required. Long random string used to sign the login session cookie.
AUTH_SECRET=replace-with-a-long-random-string

# ---- Login brute-force protection (all required, positive integers) ----
# Failed login attempts (per client IP) allowed before a lockout kicks in.
LOGIN_MAX_ATTEMPTS=5
# Base lockout duration in seconds. Escalates linearly per lockout:
# 1st lockout = base, 2nd = base x2, 3rd = base x3 (60s = 1 minute).
LOGIN_BLOCK_SECONDS=60
# Lockouts an IP may accrue before it is banned outright. A banned IP is blocked
# until the process restarts. Set higher to be more forgiving.
LOGIN_MAX_LOCKOUTS=10

# ---- Bot protection (Cloudflare Turnstile) ----
# Optional. Server-side secret key from the Turnstile widget. If empty, token
# verification is skipped (the form works unchanged). When you set this, also add
# the matching site key to the website (_config.yml: turnstile_site_key) so the
# widget renders and sends a token, otherwise every submission is rejected.
TURNSTILE_SECRET_KEY=

# ---- CORS / origin gate ----
# Optional. Comma-separated list of website origins allowed to POST bookings and
# to call the state-changing dashboard routes. Unset means "*" (any origin).
ALLOWED_ORIGINS=https://innospacetirana.com,https://www.innospacetirana.com,http://localhost:4000

# ---- Storage ----
# Optional. Path to the SQLite DB file. Defaults to ./data/bookings.db
DATA_FILE=

# ---- Plan pricing (keyed by plan slug) ----
# Currency is required; each amount is optional (an unpriced plan simply omits
# its rate line from the confirmation email).
PRICE_CURRENCY=€
PRICE_DAILY_PASS=15
PRICE_WEEKLY_PASS=60
PRICE_MONTHLY_PASS=170
PRICE_EVENT_ROOM_HOUR=25
PRICE_EVENT_ROOM_DAY=170

# ---- Business contact / access details (shown in the confirmation email) ----
# BUSINESS_NAME is required (it signs off every email). BUSINESS_WEBSITE_URL
# defaults to https://innospacetirana.com. Every other field is optional and is
# simply omitted from the email footer when blank.
BUSINESS_NAME=InnoSpace Tirana
BUSINESS_WEBSITE_URL=https://innospacetirana.com
EMAIL_SIGNOFF_NAME=
BUSINESS_ADDRESS=
BUSINESS_ACCESS_APT1=
BUSINESS_ACCESS_APT2=
BUSINESS_MAPS_URL=
BUSINESS_PHONE=
BUSINESS_EMAIL=
BUSINESS_NID=
