# ---- Email (Resend) — confirm/cancel emails to customers ----
# Get a key at https://resend.com/api-keys. If empty, emails are skipped.
RESEND_API_KEY=
# Verified Resend sender, or onboarding@resend.dev until your domain is verified.
EMAIL_FROM=onboarding@resend.dev

# ---- Dashboard login (seeds the first admin user into the DB) ----
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
# Long random string used to sign the login session cookie.
AUTH_SECRET=replace-with-a-long-random-string

# ---- Bot protection (Cloudflare Turnstile) ----
# Server-side secret key from the Turnstile widget. If empty, token verification
# is skipped (the form works unchanged). When you set this, also add the matching
# site key to the website (_config.yml: turnstile_site_key) so the widget renders
# and sends a token — otherwise every submission is rejected as unverified.
TURNSTILE_SECRET_KEY=

# ---- CORS ----
# Comma-separated list of website origins allowed to POST bookings.
# Use "*" to allow any origin (fine if you don't mind public submissions).
ALLOWED_ORIGINS=https://innospacetirana.com,https://www.innospacetirana.com,http://localhost:4000

# ---- Storage ----
# Path to the SQLite DB file. Defaults to ./data/bookings.db
DATA_FILE=

# ---- Plan pricing (keyed by plan slug) ----
PRICE_CURRENCY=€
PRICE_DAILY_PASS=15
PRICE_WEEKLY_PASS=60
PRICE_MONTHLY_PASS=170
PRICE_EVENT_ROOM_HOUR=25
PRICE_EVENT_ROOM_DAY=170

# ---- Business contact / access details (shown in the confirmation email) ----
# Any field left blank is simply omitted from the email footer.
EMAIL_SIGNOFF_NAME=
BUSINESS_NAME=InnoSpace Tirana
BUSINESS_ADDRESS=
BUSINESS_ACCESS_APT1=
BUSINESS_ACCESS_APT2=
BUSINESS_MAPS_URL=
BUSINESS_PHONE=
BUSINESS_EMAIL=
BUSINESS_NID=
